{
  "name": "prompt-guide",
  "private": true,
  "type": "module",
  "description": "Claude Code, Codex CLI, Cursor 설정을 단일 prompt-guide.yml로 통합 관리",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check packages templates",
    "format": "biome format --write packages templates",
    "pg": "node packages/cli/dist/index.js",
    "example:sync": "cd example && node ../packages/cli/dist/index.js sync",
    "example:doctor": "cd example && node ../packages/cli/dist/index.js doctor",
    "example:validate": "cd example && node ../packages/cli/dist/index.js validate",
    "example:diff": "cd example && node ../packages/cli/dist/index.js diff",
    "example:status": "cd example && node ../packages/cli/dist/index.js status"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.9.0"
}
